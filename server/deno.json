{
  "compilerOptions": {
    "strict": true
  },
  "imports": {
    "express": "npm:express@^5.1.0",
    "@types/express": "npm:@types/express@^5.0.3",
    "winston": "npm:winston@^3.17.0",
    "uuid": "npm:uuid@^11.1.0",
    "bcryptjs": "npm:bcryptjs@^3.0.3",
    "@types/bcryptjs": "npm:@types/bcryptjs@^3.0.0",
    "jose": "npm:jose@^6.0.0",
    "cookie-parser": "npm:cookie-parser@^1.4.7",
    "@types/cookie-parser": "npm:@types/cookie-parser@^1.4.8"
  },
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-write --allow-env --env-file=.env --watch index.ts",
    "seed": "deno run --allow-read --allow-write --allow-env scripts/seed.ts"
  }
