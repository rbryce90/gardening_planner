{
  "name": "garden",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "generate": "tsoa spec-and-routes",
    "build": "tsoa spec-and-routes && tsc",
    "start": "node dist/index.js",
    "dev": "tsoa spec-and-routes && NODE_OPTIONS='--experimental-sqlite' nodemon --watch './**/*.ts' --ignore './generated/**' --exec 'tsx ./index.ts'",
    "seed:neo4j": "npx tsx --experimental-sqlite scripts/seedNeo4j.ts",
    "etl:neo4j": "npx tsx --experimental-sqlite scripts/etlToNeo4j.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "jose": "^6.2.2",
    "neo4j-driver": "^6.0.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^7.0.0-alpha.0",
    "uuid": "^11.1.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
